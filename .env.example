# ── LiveKit Cloud ──────────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io → Project Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Deepgram ───────────────────────────────────────────────────────────────────
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=...

# ── Cartesia ───────────────────────────────────────────────────────────────────
# Get from: https://play.cartesia.ai/ → Settings → API Keys
CARTESIA_API_KEY=...
# Get a voice ID from: https://play.cartesia.ai/voices
# Example built-in voice: "a0e99841-438c-4a64-b679-ae501e7d6091" (Barbershop Man)
CARTESIA_VOICE_ID=...
